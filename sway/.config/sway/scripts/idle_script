#!/usr/bin/env bash
set -euxo pipefail
SIGNAL=6
pidf="${XDG_RUNTIME_DIR:-/run/user/$UID}/idle_script.pid"
LOCK_TIMEOUT=$((5 * 60))
DPMS_TIMEOUT=$((10 * 60))

is_alive() {
  [[ -s "$pidf" ]] || return 1
  local pid
  pid="$(head -n1 "$pidf" || true)"
  [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null
}

on() {
  if is_alive; then
    echo "Idle script already running (PID $(head -n1 "$pidf"))"
    exit 0
  fi
  : >"$pidf"  # clear stale pidfile

  # Ensure D-Bus session is available for logind idle detection
  if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR:-/run/user/$UID}/bus"
  fi

  swayidle -w \
    timeout "$LOCK_TIMEOUT" "$HOME/.config/sway/scripts/swaylock.sh" \
    timeout "$DPMS_TIMEOUT" 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    >/tmp/swayidle.log 2>&1 &
  echo "$!" >"$pidf"
  pkill -RTMIN+"$SIGNAL" waybar || true
}
off() {
  [[ -s "$pidf" ]] || exit 0
  pid="$(head -n1 "$pidf" || true)"
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid"
  fi
  : >"$pidf"
  pkill -RTMIN+"$SIGNAL" waybar || true
}
case "${1:-}" in
  on) on ;;
  off) off ;;
  toggle) is_alive && off || on ;;
  status) is_alive && echo running || echo stopped ;;
  *) echo "usage: $0 {on|off|toggle|status}" ; exit 2 ;;
esac
